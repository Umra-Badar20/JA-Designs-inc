/* ========== JavaScript migrated from services.html ========== */
document.addEventListener('DOMContentLoaded', function () {
                var btn = document.querySelector('.js-toggleNav');
                if (btn) {
                    btn.addEventListener('click', function (e) {
                        var isActive = btn.classList.toggle('is-active');
                        document.documentElement.classList.toggle('nav-active', isActive);
                        btn.setAttribute('aria-expanded', isActive ? 'true' : 'false');
                    });
                }

                // Handle dropdown toggles (Services menu) - icon
                document.querySelectorAll('.js-dropdown-toggle').forEach(function (dt) {
                    dt.addEventListener('click', function (e) {
                        e.preventDefault();
                        var li = dt.closest('.menu-item');
                        if (!li) return;
                        var holder = li.querySelector('.js-dropdown-menu-holder');

                        var isActive = li.classList.toggle('nav-active');
                        if (holder) holder.classList.toggle('nav-active', isActive);
                        dt.classList.toggle('nav-active', isActive);
                        dt.setAttribute('aria-expanded', isActive ? 'true' : 'false');
                    });
                });

                // Also make the main 'Services' link toggle the same dropdown (click on text)
                document.querySelectorAll('.js-menu-dropdown-toggle > .menu-link').forEach(function (link) {
                    link.addEventListener('click', function (e) {
                        // Prevent navigation so the menu can open first
                        e.preventDefault();

                        var li = link.closest('.menu-item');
                        if (!li) return;
                        var dt = li.querySelector('.js-dropdown-toggle');
                        var holder = li.querySelector('.js-dropdown-menu-holder');

                        var isActive = li.classList.toggle('nav-active');
                        if (holder) holder.classList.toggle('nav-active', isActive);
                        if (dt) {
                            dt.classList.toggle('nav-active', isActive);
                            dt.setAttribute('aria-expanded', isActive ? 'true' : 'false');
                        }
                        // set aria-expanded on the link for accessibility
                        link.setAttribute('aria-expanded', isActive ? 'true' : 'false');
                    });
                });

                // Close any open dropdown when clicking outside the nav
                document.addEventListener('click', function (e) {
                    if (!e.target.closest('.nav-main')) {
                        document.querySelectorAll('.nav-main .menu-item.nav-active').forEach(function (el) {
                            el.classList.remove('nav-active');
                            var h = el.querySelector('.js-dropdown-menu-holder');
                            if (h) h.classList.remove('nav-active');
                            var togg = el.querySelector('.js-dropdown-toggle');
                            if (togg) {
                                togg.classList.remove('nav-active');
                                togg.setAttribute('aria-expanded', 'false');
                            }
                            var link = el.querySelector('.menu-link');
                            if (link) link.setAttribute('aria-expanded', 'false');
                        });
                    }
                });

                // Sticky header on scroll: add .is-sticky when scrolled down
                var header = document.querySelector('.site-header');
                function updateSticky() {
                    if (!header) return;
                    header.classList.toggle('is-sticky', window.scrollY > 20);
                }
                window.addEventListener('scroll', updateSticky, { passive: true });
                // Initialize state
                updateSticky();
            });

